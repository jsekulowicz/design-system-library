{
  "name": "@jsekulowicz/ds-react",
  "version": "0.44.0",
  "description": "React wrappers for @jsekulowicz/ds-components built with @lit/react.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsekulowicz/design-system-library.git",
    "directory": "packages/react"
  },
  "homepage": "https://jsekulowicz.github.io/design-system-library",
  "bugs": {
    "url": "https://github.com/jsekulowicz/design-system-library/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "tsx scripts/generate-wrappers.ts",
    "build": "pnpm generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@jsekulowicz/ds-components": "workspace:*",
    "@lit/react": "^1.0.6",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
