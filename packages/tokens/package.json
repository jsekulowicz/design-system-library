{
  "name": "@jsekulowicz/ds-tokens",
  "version": "0.4.0",
  "description": "Design tokens (primitive, semantic, component) for the Design System Library.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsekulowicz/design-system-library.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://jsekulowicz.github.io/design-system-library",
  "bugs": {
    "url": "https://github.com/jsekulowicz/design-system-library/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./base.css": "./dist/base.css",
    "./theme-default-light.css": "./dist/theme-default-light.css",
    "./theme-default-dark.css": "./dist/theme-default-dark.css",
    "./theme-default.css": "./dist/theme-default.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node dist/build.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  }
}
