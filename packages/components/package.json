  "scripts": {
    "dev": "pnpm generate:icons && tsc -p tsconfig.json --watch",
    "generate:icons": "node scripts/generate-heroicons.mjs",
    "build": "pnpm generate:icons && tsc -p tsconfig.json && node scripts/copy-css.mjs && cem analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.test.ts\" --outdir .",
    "typecheck": "pnpm generate:icons && tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit",
    "analyze": "cem analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.test.ts\" --outdir ."
  },
  "size-limit": [
    {
      "name": "ds-button (subpath + define, gzip)",
      "path": [
        "dist/atoms/button/index.js",
        "dist/atoms/button/define.js"
      ],
      "limit": "16 kB"
    },
    {
      "name": "ds-text-field (subpath + define, gzip)",
      "path": [
        "dist/atoms/text-field/index.js",
        "dist/atoms/text-field/define.js"
      ],
      "limit": "18 kB"
    },
    {
      "name": "full barrel (define, gzip)",
      "path": "dist/define.js",
      "limit": "50 kB"
    }
  ],
  "dependencies": {
    "@jsekulowicz/ds-core": "workspace:*",
    "@jsekulowicz/ds-tokens": "workspace:*",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "heroicons": "2.2.0",
    "@custom-elements-manifest/analyzer": "^0.10.4",
    "@open-wc/testing": "^4.0.0",
    "@size-limit/esbuild": "^11.1.6",
    "@size-limit/file": "^11.1.6",
    "jsdom": "^25.0.1",
    "size-limit": "^11.1.6",
    "typescript": "^5.7.2",
    "vitest": "^2.1.5"
  }
}
