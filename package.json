{
  "name": "design-system-library",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Framework-agnostic design system built on Lit web components, atomic design, token-based theming.",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "build:tokens": "pnpm --filter @ds/tokens build",
    "dev": "pnpm --filter @ds/core build && pnpm --filter @ds/components build && pnpm --parallel --filter \"@ds/core\" --filter \"@ds/components\" --filter \"@ds/storybook\" dev",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "pnpm -r --parallel lint",
    "lint:lit": "eslint \"packages/{components,core}/src/**/*.ts\" --max-warnings=0",
    "test": "pnpm -r --parallel test",
    "test:coverage": "pnpm --filter @ds/components test:coverage",
    "test:coverage:all": "pnpm -r --parallel --if-present test:coverage",
    "test:e2e": "pnpm --filter @ds/tests test:e2e",
    "test:a11y": "pnpm --filter @ds/tests test:a11y",
    "size": "pnpm -r --parallel size",
    "analyze": "pnpm --filter @ds/components analyze",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-istanbul": "^2.1.9",
    "eslint": "^9.15.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-wc": "^3.1.0",
    "lit-analyzer": "^2.0.3",
    "prettier": "^3.4.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.1"
  }
}
